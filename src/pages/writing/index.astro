---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import topics from '../../data/topics.json';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const readMins = (entry: any) => Math.max(1, Math.round((entry.body || '').split(/\s+/).filter(Boolean).length / 200));
const tagCount = (tag: string) => posts.filter((p) => p.data.tags.includes(tag)).length;
const visibleTopics = topics
  .map((t) => ({
    ...t,
    count: tagCount(t.tag),
    sub: (t.sub || []).map((s) => ({ ...s, count: tagCount(s.tag) })).filter((s) => s.count > 0),
  }))
  .filter((t) => t.count > 0 || t.sub.length > 0);
---
<Base title="Writing" description="Every post, newest first — browse by topic." progress>
  <section class="section writing-archive">
    <div class="orbs"><div class="orb orb-b" style="opacity:0.3"></div></div>
    <div class="container">

      <header class="archive-head" data-reveal>
        <h1 class="display">Writing</h1>
        <p class="lead">My blog.</p>
      </header>

      <div class="writing-grid">
        <!-- side navigation: topic rail — desktop sidebar, mobile collapsible accordion -->
        <aside class="topic-rail" data-reveal="left">
          <details class="topic-acc">
            <summary class="rail-title">Topics <span class="acc-caret" aria-hidden="true">▾</span></summary>
            <ul class="topic-list" id="topic-list">
              <li>
                <button class="topic-btn active" data-filter="*">
                  All posts <span class="count">{posts.length}</span>
                </button>
              </li>
              {visibleTopics.map((t) => (
                <li>
                  {t.sub.length > 0 ? (
                    <details class="topic-group">
                      <summary class="topic-btn" data-filter={t.tag}>
                        <span class="grp-caret" aria-hidden="true">▾</span>
                        <span class="topic-name">{t.name}</span>
                        {t.subtitle && <span class="topic-subtitle">{t.subtitle}</span>}
                        <span class="count">{t.count}</span>
                      </summary>
                      <ul class="topic-sub">
                        {t.sub.map((s) => (
                          <li>
                            <button class="topic-btn" data-filter={s.tag}>
                              {s.name} <span class="count">{s.count}</span>
                            </button>
                          </li>
                        ))}
                      </ul>
                    </details>
                  ) : (
                    <button class="topic-btn" data-filter={t.tag}>
                      <span class="topic-name">{t.name}</span>
                      {t.subtitle && <span class="topic-subtitle">{t.subtitle}</span>}
                      <span class="count">{t.count}</span>
                    </button>
                  )}
                </li>
              ))}
            </ul>
          </details>
        </aside>

        <div class="post-col">
          <!-- mobile-only topic bar (top) — tap a topic to filter; topics with subtopics reveal them -->
          <nav class="wt-bar" aria-label="Browse by topic">
            <div class="wt-row">
              <button class="wt-chip topic-btn active" data-filter="*">All</button>
              {visibleTopics.map((t) => (
                <button class={`wt-chip topic-btn${t.sub.length ? ' has-sub' : ''}`} data-filter={t.tag} data-topic={t.tag}>{t.name}{t.sub.length ? <span class="wt-car" aria-hidden="true">▾</span> : null}</button>
              ))}
            </div>
            {visibleTopics.filter((t) => t.sub.length > 0).map((t) => (
              <div class="wt-subs" data-subs={t.tag} hidden>
                {t.sub.map((s) => <button class="wt-chip wt-sub topic-btn" data-filter={s.tag}>{s.name} <span class="count">{s.count}</span></button>)}
              </div>
            ))}
          </nav>
          <div class="density-toggle" role="group" aria-label="List density">
            <button class="dt-btn" data-density="comfortable">Comfortable</button>
            <button class="dt-btn" data-density="compact">Compact</button>
          </div>
          <div id="filterBanner" class="filter-banner" hidden></div>
          <div class="post-list" id="post-list">
            {posts.map((p, i) => (
              <PostCard post={p} readMins={readMins(p)} reveal delay={Math.min(i * 0.05, 0.3)} />
            ))}
            <p class="no-posts" id="no-posts" hidden>Nothing here yet — pick another topic.</p>
          </div>
          <!-- mobile-only topic bar (bottom) -->
          <nav class="wt-bar wt-bar-bottom" aria-label="Browse by topic">
            <div class="wt-row">
              <button class="wt-chip topic-btn active" data-filter="*">All</button>
              {visibleTopics.map((t) => (
                <button class={`wt-chip topic-btn${t.sub.length ? ' has-sub' : ''}`} data-filter={t.tag} data-topic={t.tag}>{t.name}{t.sub.length ? <span class="wt-car" aria-hidden="true">▾</span> : null}</button>
              ))}
            </div>
            {visibleTopics.filter((t) => t.sub.length > 0).map((t) => (
              <div class="wt-subs" data-subs={t.tag} hidden>
                {t.sub.map((s) => <button class="wt-chip wt-sub topic-btn" data-filter={s.tag}>{s.name} <span class="count">{s.count}</span></button>)}
              </div>
            ))}
          </nav>
        </div>
      </div>

    </div>
  </section>
</Base>

<style>
  .writing-archive { position: relative; }
  .writing-archive .container { position: relative; z-index: 1; }
  .archive-head { margin-bottom: 0.8rem; }
  .archive-head .display { font-size: clamp(1.4rem, 4vw, 2rem); }
  .archive-head .lead { margin-top: 0.25rem; max-width: 54ch; font-size: 0.95rem; }

  /* mobile topic bars (reader nav) — hidden on desktop, where the sidebar handles it */
  .wt-bar { display: none; }
  @media (max-width: 880px) {
    .topic-rail { display: none; }                 /* sidebar → replaced by the bars on mobile */
    .wt-bar { display: block; margin-bottom: 0.9rem; }
    .wt-bar-bottom { margin: 1.4rem 0 0; }
    .wt-row { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    /* override .topic-btn (width:100% / space-between) → compact auto-width pills */
    .wt-bar .wt-chip {
      width: auto; flex: 0 0 auto; display: inline-flex; align-items: center;
      justify-content: center; gap: 0.35em;
      font-family: var(--font-display); font-size: 0.82rem; color: var(--ink-dim);
      border: 1px solid var(--line-strong); border-radius: 99px; padding: 0.42em 0.9em;
      background: rgba(140, 160, 200, 0.05); cursor: pointer; -webkit-tap-highlight-color: transparent;
    }
    .wt-bar .wt-chip.active { color: var(--bg-0); background: var(--cyan); border-color: var(--cyan); font-weight: 700; }
    .wt-car { font-size: 0.7em; opacity: 0.7; }
    .wt-subs { display: none; }
    .wt-subs:not([hidden]) { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.55rem 0 0.2rem; padding-left: 0.15rem; }
    .wt-bar .wt-sub { font-size: 0.78rem; background: rgba(34, 211, 238, 0.07); border-color: rgba(34, 211, 238, 0.28); color: var(--cyan); }
    .wt-bar .wt-sub .count { font-size: 0.72em; opacity: 0.75; border-color: rgba(34,211,238,0.3); }
  }

  .writing-grid {
    display: grid; grid-template-columns: 230px 1fr; gap: 3rem; align-items: start;
  }
  @media (max-width: 880px) { .writing-grid { grid-template-columns: minmax(0, 1fr); gap: 1.6rem; } }

  .post-list { display: grid; gap: 0.8rem; }
  /* .post-card is a child component (own scope) → :global so the filter can hide it */
  :global(.post-card.hidden-by-filter) { display: none; }

  /* density toggle */
  .density-toggle { display: flex; gap: 0.3rem; justify-content: flex-end; margin-bottom: 0.7rem; }
  .dt-btn {
    font-family: var(--font-display); font-size: 0.76rem; color: var(--ink-faint);
    padding: 0.32em 0.75em; border: 1px solid var(--line-strong); border-radius: 99px;
    background: transparent; cursor: pointer; -webkit-tap-highlight-color: transparent;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }
  .dt-btn:hover { color: var(--ink-dim); }
  .dt-btn[aria-pressed="true"] {
    color: var(--ink); border-color: rgba(34, 211, 238, 0.4); background: rgba(34, 211, 238, 0.08);
  }
  /* compact: dense rows, no description, tighter padding */
  .post-list.density-compact { gap: 0.4rem; }
  .post-list.density-compact :global(.post-card) { padding: 0.65rem 0.9rem 0.65rem 1.1rem; }
  .post-list.density-compact :global(.post-card p) { display: none; }
  .post-list.density-compact :global(.post-card h3) { font-size: 1rem; margin-top: 0.15rem; }
  .post-list.density-compact :global(.post-meta) { font-size: 0.72rem; }
  .filter-banner {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    margin-bottom: 0.9rem; padding: 0.6em 0.9em;
    border: 1px solid rgba(34, 211, 238, 0.3); border-radius: 12px;
    background: rgba(34, 211, 238, 0.07);
    font-family: var(--font-display); font-size: 0.92rem; color: var(--ink-dim);
  }
  .filter-banner b { color: var(--ink); }
  .fb-clear {
    margin-left: auto; font-size: 0.8rem; color: var(--cyan);
    background: transparent; border: 1px solid rgba(34, 211, 238, 0.4);
    border-radius: 99px; padding: 0.25em 0.85em; cursor: pointer;
  }
  .fb-clear:hover { background: rgba(34, 211, 238, 0.12); }
  .no-posts { color: var(--ink-faint); padding: 2rem 0; }
  .topic-subtitle { color: var(--muted, #5b6b80); font-size: .78em; margin-left: .45em; letter-spacing: .04em; }
</style>

<script>
  function initArchiveFilter() {
    const postList = document.getElementById('post-list');
    if (!postList || postList.dataset.fbound) return;
    postList.dataset.fbound = '1';
    const list = document.getElementById('topic-list');

    // every topic control drives the filter: desktop sidebar + both mobile bars + subtopics
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.topic-btn'));
    const cards = Array.from(postList.querySelectorAll<HTMLElement>('.post-card'));
    const empty = document.getElementById('no-posts');

    const banner = document.getElementById('filterBanner');
    function apply(tag: string) {
      buttons.forEach((b) => b.classList.toggle('active', b.dataset.filter === tag));
      let shown = 0;
      cards.forEach((c) => {
        const tags = (c.dataset.tags || '').split(',');
        const show = tag === '*' || tags.includes(tag);
        c.classList.toggle('hidden-by-filter', !show);
        if (show) {
          shown++;
          // The scroll-reveal (gsap.from opacity:0/translateY, once) leaves cards that never
          // scrolled into view permanently hidden. Filtering promotes them to the top but GSAP
          // still holds them invisible — so force any card shown by an explicit topic filter
          // into its visible end-state. (Default '*' view keeps the natural reveal-on-scroll.)
          if (tag !== '*') { c.style.opacity = '1'; c.style.transform = 'none'; }
        }
      });
      if (empty) empty.hidden = shown > 0;
      history.replaceState(null, '', tag === '*' ? location.pathname : `#${tag}`);
      // active-filter banner — makes the filtered set unmistakable
      if (banner) {
        if (tag === '*') { banner.hidden = true; banner.innerHTML = ''; }
        else {
          const ab = buttons.find((b) => b.dataset.filter === tag);
          const nm = ab?.querySelector('.topic-name')?.textContent?.trim()
            || ab?.textContent?.replace(/\s*\d+\s*$/, '').trim() || tag;
          banner.hidden = false;
          banner.innerHTML = `Showing <b>${nm}</b> · ${shown} post${shown === 1 ? '' : 's'}<button class="fb-clear" type="button">Show all</button>`;
        }
      }
    }
    banner?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.fb-clear')) apply('*');
    });

    const acc = list ? (list.closest('details.topic-acc') as HTMLDetailsElement | null) : null;
    const isMobile = () => window.matchMedia('(max-width: 880px)').matches;
    buttons.forEach((b) => b.addEventListener('click', () => {
      apply(b.dataset.filter || '*');

      // Mobile bar: tapping a top-level topic chip reveals its subtopics (within that bar);
      // a topic with subs stays put so you can drill in, anything else is a final choice.
      const isTopChip = b.classList.contains('wt-chip') && !b.classList.contains('wt-sub');
      const revealedSubs = isTopChip && b.classList.contains('has-sub');
      if (isTopChip) {
        const bar = b.closest('.wt-bar');
        bar?.querySelectorAll<HTMLElement>('.wt-subs').forEach((sub) => {
          sub.hidden = !(revealedSubs && sub.dataset.subs === b.dataset.topic);
        });
      }

      const isGroupSummary = b.tagName === 'SUMMARY';
      if (isMobile() && !isGroupSummary && !revealedSubs) {
        if (acc) acc.open = false;
        const col = postList.closest('.post-col') as HTMLElement | null;
        if (col) {
          const y = col.getBoundingClientRect().top + window.scrollY - 70;
          window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
        }
      }
    }));

    const hash = location.hash.slice(1);
    if (hash && buttons.some((b) => b.dataset.filter === hash)) apply(hash);
  }

  function initDensity() {
    const wrap = document.querySelector<HTMLElement>('.density-toggle');
    const list = document.getElementById('post-list');
    if (!wrap || !list || wrap.dataset.bound) return;
    wrap.dataset.bound = '1';
    const btns = Array.from(wrap.querySelectorAll<HTMLButtonElement>('.dt-btn'));
    const set = (mode: string) => {
      list.classList.toggle('density-compact', mode === 'compact');
      btns.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.density === mode)));
      try { localStorage.setItem('writing-density', mode); } catch (e) {}
    };
    btns.forEach((b) => b.addEventListener('click', () => set(b.dataset.density || 'comfortable')));
    let saved = 'comfortable';
    try { saved = localStorage.getItem('writing-density') || 'comfortable'; } catch (e) {}
    set(saved);
  }

  document.addEventListener('astro:page-load', initArchiveFilter);
  document.addEventListener('astro:page-load', initDensity);
</script>
